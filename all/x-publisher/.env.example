# x-publisher MCP defaults
X_PUBLISHER_MODE=dry-run
X_PUBLISHER_MCP_HOST=127.0.0.1
X_PUBLISHER_MCP_PORT=8765

# Set these only when a separately configured official XMCP server is running.
# Live mode still requires confirmation on every mutating x-publisher tool.
X_PUBLISHER_ALLOW_LIVE=0
X_PUBLISHER_BACKEND=auto
X_PUBLISHER_XMCP_URL=http://127.0.0.1:8000/mcp

# Optional direct X API v2 backend. Requires a user-context token with Post
# permissions. Keep this in your local environment only; never commit it.
X_PUBLISHER_X_API_BASE_URL=https://api.x.com
X_PUBLISHER_X_USER_ACCESS_TOKEN=
